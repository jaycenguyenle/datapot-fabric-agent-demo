partition Date = calculated
mode: import
source =
VAR StartDate = DATE(2025, 1, 1)
VAR EndDate = DATE(2025, 6, 30)
RETURN
ADDCOLUMNS(
CALENDAR(StartDate, EndDate),
"Year", YEAR([Date]),
"MonthNumber", MONTH([Date]),
"MonthName", FORMAT([Date], "MMMM"),
"MonthYear", FORMAT([Date], "MMM yyyy")
)
